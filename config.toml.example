# WyrmGPT TOML config example
# Place as config.toml in the repo root.
# Values here are non-secret defaults and normal app settings.
# Secrets live in config.secrets.toml.
# TOML values take precedence; .env remains as fallback during migration.

[core]
system_prompt_file = ".\\prompts\\callie3rd_prompt.txt"
# default_system_prompt = "You are a helpful assistant..."
debug_mode = true
debug_errors = true

[providers.openai]
model = "gpt-5.4"
summary_model = "gpt-5-mini"

[ui]
local_timezone = "America/New_York"
context_preview_limit_min = 20
context_preview_limit_max = 200
min_rag_query_text_len = 5
context_idle_ms = 5000
transcript_idle_ms = 120000
debug_boot = true

[summary]
summary_max_tokens = 800
summary_conversation_prompt_file = ".\\prompts\\_summary_convo_prompt.txt"
summary_reduce_threshold_chars = 18000
summary_chunk_target_chars = 7000
summary_chunk_hard_max_chars = 10000
summary_chunk_max_tokens = 350

[context]
max_tokens = 12000
memory_pin_limit = 250
history_limit = 200
preview_limit = 20
estimate_model = "gpt-5-mini"

[retrieval]
query_include = ["CHAT_SUMMARY", "FTS", "EMBEDDING"]
query_expand_results = ["FILE", "MEMORY", "CHAT"]
query_max_full_files = 50
query_max_full_memories = 500
query_max_full_chats = 5
query_expand_min_artifact_hits = 2
query_expand_chat_window_before = 1
query_expand_chat_window_after = 1
query_global_artifacts = true
max_terms = 14
max_phrase_words = 8
max_phrase_chars = 64
filler_words_file = ".\\FTS filler+stop words.txt"
long_query_chars = 400
max_query_slices = 6
llm_expand_enabled = true
llm_expand_prompt_file = ".\\prompts\\_expand_query_prompt.txt"
llm_expand_min_terms = 4
llm_expand_min_results = 3
llm_expand_max_keywords = 10
llm_expand_model = "gpt-5-mini"
llm_expand_max_tokens = 800
retrieval_cache_ttl_sec = 180.0
retrieval_cache_max_entries = 64
query_include_project_conversation_transcripts = true
query_include_global_conversation_transcripts = true
query_include_recent_conversation_transcripts = true
recent_conversation_transcript_limit = 40

[embeddings]
provider = "openai"
model = "text-embedding-3-large"
dimensions = 0
batch_size = 64
cache_enabled = true
cache_dir = ".\\data\\embedding_cache"

[vector]
backend = "qdrant_local"
collection_name = "wyrmgpt_chunks"
local_path = ".\\data\\qdrant"
server_url = ""
distance_metric = "cosine"
search_limit = 24

[app]
search_chat_history = true
